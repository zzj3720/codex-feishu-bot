# 仅用于本地开发或 fake-feishu 调试，不是公开部署主路径
HOST=0.0.0.0
PORT=3000
CODEX_MODE=mock
CODEX_APP_SERVER_COMMAND=codex
CODEX_APP_SERVER_ARGS=app-server
CODEX_APP_SERVER_LISTEN_URL=ws://127.0.0.1:4500
CODEX_APP_SERVER_MANAGED=true
CODEX_APP_SERVER_MODEL=gpt-5.4
CODEX_APP_SERVER_APPROVAL_POLICY=never
CODEX_APP_SERVER_SANDBOX=danger-full-access
# 本地开发默认工作目录。Codex 默认不直接把仓库根目录当作运行工作区
DEFAULT_WORKSPACE=.codex-local/workspace
# 默认导出产物目录。给用户的 ppt/pdf/xlsx 等文件优先写到这里
CODEX_ARTIFACTS_DIR=artifacts
# 运行态快照文件。用于容器重启后恢复 chat -> thread 映射和最近消息投影
RUNTIME_STATE_FILE=.codex-feishu-bot/runtime-state.json
LIVE_UPDATE_DEBOUNCE_MS=1200
FEISHU_PROVIDER=sdk
FEISHU_TRANSPORT=websocket
FEISHU_DOMAIN=feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FAKE_FEISHU_BASE_URL=http://127.0.0.1:3400
FAKE_FEISHU_WS_URL=ws://127.0.0.1:3400/ws
