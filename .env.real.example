COMPOSE_PROJECT_NAME=codex-feishu-bot-real

# 对外暴露给宿主机的 app 端口
APP_PORT=3000
# Docker 内 /workspace 对应的宿主机工作目录。不要把整个仓库根目录挂进去
CODEX_WORKSPACE_HOST_PATH=.codex-local/workspace
# 容器内默认导出产物目录，位于运行时工作目录里
CODEX_ARTIFACTS_DIR=/workspace/artifacts
# 运行态快照文件，和工作目录一起持久化
RUNTIME_STATE_FILE=/workspace/.codex-feishu-bot/runtime-state.json
# 飞书消息更新的防抖窗口，调试时可压低
LIVE_UPDATE_DEBOUNCE_MS=1200

# 飞书区域，一般保持 feishu
FEISHU_DOMAIN=feishu
# 由 Codex 通过飞书开放平台自动化配置后写回
FEISHU_APP_ID=
# 由 Codex 通过飞书开放平台自动化配置后写回
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

# 运行时 Codex worker 模型，可按需调整
CODEX_APP_SERVER_MODEL=gpt-5.4
CODEX_CLI_VERSION=0.111.0

# 认证方式二选一。
# 1. 推荐：把宿主机已有的 ~/.codex 挂进容器，写宿主机绝对路径
CODEX_HOME_SOURCE=codex-home
# 2. 或者填 OPENAI_API_KEY，容器首次启动时会自动 codex login
OPENAI_API_KEY=
